# ============================================================
# AGY Bug Bounty MCP - Environment Configuration
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control!
# ============================================================

# --- Shodan (https://shodan.io) ---
SHODAN_API_KEY=your_shodan_api_key_here

# --- GitHub (https://github.com/settings/tokens) ---
# Required scopes: repo, read:org
GITHUB_TOKEN=your_github_personal_access_token_here

# --- VirusTotal (https://virustotal.com) ---
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# --- SecurityTrails (https://securitytrails.com) ---
# COMING SOON - belum diimplementasikan di tools
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# --- Hunter.io (https://hunter.io) ---
# COMING SOON - belum diimplementasikan di tools
HUNTER_IO_API_KEY=your_hunterio_api_key_here

# --- HaveIBeenPwned (https://haveibeenpwned.com/API/Key) ---
# COMING SOON - belum diimplementasikan di tools
HIBP_API_KEY=your_hibp_api_key_here

# --- Censys (https://censys.io) ---
# COMING SOON - belum diimplementasikan di tools
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here

# --- URLScan.io (https://urlscan.io) ---
# COMING SOON - belum diimplementasikan di tools
URLSCAN_API_KEY=your_urlscan_api_key_here

# --- WhoAPI (https://whoapi.com) ---
# COMING SOON - belum diimplementasikan di tools
WHOAPI_KEY=your_whoapi_key_here

# --- Interactsh (for SSRF/OOB callback) ---
# Leave empty to use default public server (interactsh.com)
INTERACTSH_SERVER=
INTERACTSH_TOKEN=

# --- General Settings ---
# Default request timeout in seconds
REQUEST_TIMEOUT=30

# Default delay between requests (rate limiting)
REQUEST_DELAY=0.5

# Max concurrent requests
MAX_CONCURRENT_REQUESTS=5

# User agent string
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Database path (relative to project root)
DB_PATH=database/bugbounty.db

# Reports output directory
REPORTS_DIR=reports
